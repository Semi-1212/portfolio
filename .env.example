# Production: set on Vercel (Settings → Environment Variables) so OG/Twitter images use absolute URLs at build time.
VITE_SITE_URL=https://your-deployment.vercel.app

# Optional: Formspree form endpoint (show contact form when set)
# VITE_FORMSPREE_ACTION=https://formspree.io/f/xxxxxxxx

# Optional: Calendly (or Cal.com) scheduling URL
# VITE_CALENDLY_URL=https://calendly.com/yourname/intro

# Optional: Plausible Analytics domain (no cookie banner typical use case)
# VITE_PLAUSIBLE_DOMAIN=yourdomain.com
